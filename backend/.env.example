# Порт сервера
PORT=3000

# Режим работы
#   true  = демо-режим (mock-данные, без GigaChat)
#   false = реальный режим (требуется GIGACHAT_AUTH_KEY)
DEMO_MODE=false

# GigaChat credentials
# Формат: "client_id:client_secret"
# Получить: https://developers.sber.ru/docs/ru/gigachat/api/reference/rest/post/token
# После регистрации на developers.sber.ru создайте проект и скопируйте ключ
GIGACHAT_AUTH_KEY=

# Scope для доступа к API
#   GIGACHAT_API_PERS — персональный контур (рекомендуется)
#   GIGACHAT_API_B2B  — B2B-контур
#   GIGACHAT_API_CORP — корпоративный контур
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель GigaChat
#   GigaChat-2-Pro  — рекомендуется
#   GigaChat-Pro
#   GigaChat-Max
GIGACHAT_MODEL=GigaChat-2-Pro
