# Порт сервера
PORT=3000

# GigaChat credentials
# Получить можно в личном кабинете GigaChat: https://developers.sber.ru/docs/ru/gigachat/api/reference/rest/post/token

# Авторизационный ключ (формата: "xxxx:xxxx")
GIGACHAT_AUTH_KEY=your_auth_key_here

# Scope для доступа к API
# Возможные значения:
#   GIGACHAT_API_B2B — для B2B-контур (основной, рекомендуется)
#   GIGACHAT_API_CORP — для корпоративного контура
#   GIGACHAT_API_PERS  — для персонального контура
GIGACHAT_SCOPE=GIGACHAT_API_B2B

# Модель GigaChat
# Доступные варианты:
#   GigaChat        — базовая версия
#   GigaChat-Pro    — продвинутая версия
#   GigaChat-2-Pro  — последняя версия (рекомендуется)
#   GigaChat-Max    — максимальная версия
GIGACHAT_MODEL=GigaChat-2-Pro