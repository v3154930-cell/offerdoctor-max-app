# Порт сервера
PORT=3000

# Режим работы
#   true  = демо-режим (mock-данные, без GigaChat)
#   false = реальный режим (требуется GIGACHAT_AUTH_KEY)
DEMO_MODE=false

# GigaChat credentials
# Формат: "client_id:client_secret"
# Получить: https://developers.sber.ru/docs/ru/gigachat/api/reference/rest/post/token
# После регистрации на developers.sber.ru создайте проект и скопируйте ключ
GIGACHAT_AUTH_KEY=

# Scope для доступа к API
#   GIGACHAT_API_PERS — персональный контур (рекомендуется)
#   GIGACHAT_API_B2B  — B2B-контур
#   GIGACHAT_API_CORP — корпоративный контур
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель GigaChat
#   GigaChat-2-Pro  — рекомендуется
#   GigaChat-Pro
#   GigaChat-Max
GIGACHAT_MODEL=GigaChat-2-Pro

# ========================
# Robokassa (опционально)
# ========================
# ВАЖНО: Для получения callback от Robokassa нужен публичный HTTPS URL.
# Locahost не работает — используйте ngrok или deployed сервер.

# Базовый публичный URL приложения (без trailing slash)
# Пример: https://offerdoctor-api.onrender.com
# Если не задан — используется хост из запроса (может быть localhost)
# ROBOKASSA_BASE_URL=https://your-domain.com

# Login в системе Robokassa (получить при регистрации магазина)
# ROBOKASSA_LOGIN=your_shop_login

# Пароль для формирования сигнатуры (Password1)
# Настройки магазина → Настройки безопасности → Дополнительные пароли
# ROBOKASSA_PASSWORD1=your_password1

# Тестовый режим
#   true  = тестовый шлюз (IsTest=1) — для проверки интеграции
#   false = боевой шлюз — только после модерации Robokassa
# ROBOKASSA_IS_TEST=true

# URL для callback (ResultURL) — Robokassa шлёт POST после оплаты
# Автоматически: {ROBOKASSA_BASE_URL}/api/payment/result
# ROBOKASSA_RESULT_URL=

# URL для редиректа после успешной оплаты
# Автоматически: {ROBOKASSA_BASE_URL}/#?orderId={InvId}
# ROBOKASSA_SUCCESS_URL=

# URL для редиректа после отмены оплаты
# ROBOKASSA_FAIL_URL=

# ========================
# Knowledge Engine (RAG)
# ========================

# Включить RAG-интеграцию
#   true  = использовать базу знаний для обогащения промптов
#   false = работать без RAG (по-старому)
ENABLE_RAG=false

# URL запущенного knowledge-engine сервиса
# Пример: http://127.0.0.1:8000
KNOWLEDGE_ENGINE_URL=http://127.0.0.1:8000

# ID проекта в knowledge-engine (создаётся через API)
# Пример: ke_abc123...
KNOWLEDGE_PROJECT_ID=

# Количество результатов для retrieval
# Рекомендуется: 3-5
RAG_TOP_K=5