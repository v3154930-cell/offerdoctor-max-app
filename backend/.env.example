# Порт сервера
PORT=3000

# Demo mode: true = использовать mock-данные без GigaChat credentials
# Установите true для тестирования и демонстрации
DEMO_MODE=true

# GigaChat credentials
# Получить: https://developers.sber.ru/docs/ru/gigachat/api/reference/rest/post/token

# Авторизационный ключ (формата: "client_id:client_secret")
GIGACHAT_AUTH_KEY=

# Scope для доступа к API
#   GIGACHAT_API_PERS — персональный контур
#   GIGACHAT_API_B2B  — B2B-контур
#   GIGACHAT_API_CORP — корпоративный контур
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель GigaChat
#   GigaChat-2-Pro  — рекомендуется
#   GigaChat-Pro
#   GigaChat-Max
GIGACHAT_MODEL=GigaChat-2-Pro
