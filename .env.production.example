# Supabase Configuration for Vercel Production
# Add these to Vercel Project Settings → Environment Variables → Production

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service role key from Supabase (Settings → API → Project settings)
# WARNING: Use service_role key (not anon key) for server-side operations
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Robokassa configuration (if using real payments)
# ROBOKASSA_LOGIN=your_shop_login
# ROBOKASSA_PASSWORD1=your_password1
# ROBOKASSA_IS_TEST=true
# ROBOKASSA_BASE_URL=https://offerdoctor-max-app.vercel.app